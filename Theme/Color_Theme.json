{
  "name": "World Class Premium Minimalist (The Best Design)",
  "dataColors": [
    "#6366F1",
    "#3B82F6",
    "#10B981",
    "#F59E0B",
    "#EC4899",
    "#8B5CF6",
    "#14B8A6",
    "#F43F5E"
  ],
  "background": "#F8FAFC",
  "foreground": "#0F172A",
  "tableAccent": "#6366F1",
  "good": "#10B981",
  "neutral": "#F59E0B",
  "bad": "#EF4444",
  "maximum": "#6366F1",
  "center": "#A78BFA",
  "minimum": "#E2E8F0",
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F8FAFC" } },
            "transparency": 0
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": { "solid": { "color": "#F8FAFC" } },
            "foregroundColor": { "solid": { "color": "#0F172A" } }
          }
        ]
      }
    },
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#F1F5F9" } },
            "radius": 16
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": { "solid": { "color": "#CBD5E1" } },
            "position": "Outer",
            "preset": "Bottom",
            "shadowBlur": 16,
            "shadowSpread": 0,
            "transparency": 70
          }
        ],
        "title": [
          {
            "show": true,
            "fontFamily": "Segoe UI Semibold, wf_segoe-ui_semibold",
            "fontSize": 14,
            "fontColor": { "solid": { "color": "#0F172A" } },
            "alignment": "Left"
          }
        ]
      }
    },
    "card": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#6366F1" } },
            "transparency": 0
          }
        ],
        "labels": [
          {
            "fontFamily": "Segoe UI Bold, wf_segoe-ui_bold",
            "fontSize": 32,
            "color": { "solid": { "color": "#FFFFFF" } }
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "fontFamily": "Segoe UI Semibold, wf_segoe-ui_semibold",
            "fontSize": 12,
            "color": { "solid": { "color": "#E0E7FF" } }
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#F1F5F9" } },
            "gridHorizontalWeight": 1
          }
        ],
        "columnHeaders": [
          {
            "fontFamily": "Segoe UI Semibold, wf_segoe-ui_semibold",
            "fontSize": 11,
            "fontColor": { "solid": { "color": "#475569" } },
            "backColor": { "solid": { "color": "#F8FAFC" } }
          }
        ],
        "values": [
          {
            "fontFamily": "Segoe UI, wf_segoe-ui_normal",
            "fontSize": 11,
            "fontColor": { "solid": { "color": "#334155" } },
            "backColorPrimary": { "solid": { "color": "#FFFFFF" } },
            "backColorSecondary": { "solid": { "color": "#FFFFFF" } }
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontFamily": "Segoe UI, wf_segoe-ui_normal",
            "fontSize": 11,
            "fontColor": { "solid": { "color": "#334155" } },
            "background": { "solid": { "color": "#FFFFFF" } }
          }
        ],
        "header": [
          {
            "fontFamily": "Segoe UI Semibold, wf_segoe-ui_semibold",
            "fontSize": 12,
            "fontColor": { "solid": { "color": "#0F172A" } }
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#F1F5F9" } },
            "radius": 12
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": { "solid": { "color": "#CBD5E1" } },
            "position": "Outer",
            "preset": "Bottom",
            "shadowBlur": 10,
            "shadowSpread": 0,
            "transparency": 80
          }
        ]
      }
    }
  }
}